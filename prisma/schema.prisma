generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WGConfig {
  id         String   @id @default(cuid())
  name       String
  avatarUrl  String?
  inviteCode String   @unique @default(cuid())
  createdAt  DateTime @default(now())

  members          User[]
  duties           Duty[]
  assignments      DutyAssignment[]
  swapRequests     SwapRequest[]
  dutySwapIOUs     DutySwapIOU[]
  announcements    Announcement[]
  shoppingItems    ShoppingItem[]
  expenses         Expense[]
  settlements      Settlement[]
  expenseCategories WGExpenseCategory[]
  notifications    Notification[]
  inviteTokens     InviteToken[]
  spotifyPlaylists SpotifyPlaylist[]
  icalCalendars    ICalCalendar[]
  gameSessions     GameSession[]
  wgEvents         WGEvent[]
}

model User {
  id                 String    @id @default(cuid())
  wgId               String
  name               String
  email              String    @unique
  passwordHash       String
  avatarUrl          String?
  role               Role      @default(MEMBER)
  emailNotifications Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  wg               WGConfig               @relation(fields: [wgId], references: [id], onDelete: Cascade)
  assignments        DutyAssignment[]
  swapRequestsFrom   SwapRequest[]          @relation("SwapFrom")
  swapRequestsTo     SwapRequest[]          @relation("SwapTo")
  iouAsDebitor       DutySwapIOU[]          @relation("IouDebitor")
  iouAsCreditor      DutySwapIOU[]          @relation("IouCreditor")
  announcements      Announcement[]
  reactions          AnnouncementReaction[]
  shoppingItems      ShoppingItem[]
  expenses           Expense[]
  settlementsFrom    Settlement[]           @relation("SettlementFrom")
  settlementsTo      Settlement[]           @relation("SettlementTo")
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
  spotifyPlaylists   SpotifyPlaylist[]
  gameResults           GameResult[]
  createdGames          GameSession[]          @relation("GameCreator")
  createdWGEvents       WGEvent[]              @relation("WGEventCreator")
  assignedAnnouncements Announcement[]         @relation("AnnouncementAssignee")

  @@index([wgId])
}

enum Role {
  ADMIN
  MEMBER
}

model Duty {
  id               String           @id @default(cuid())
  wgId             String
  name             String
  description      String?
  emoji            String?
  color            String           @default("#6366f1")
  rotationInterval RotationInterval @default(WEEKLY)
  dueWeekday       Int?
  isActive         Boolean          @default(true)
  isPaused         Boolean          @default(false)
  rotationOrder    String[]
  checklistItems   String[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  wg          WGConfig         @relation(fields: [wgId], references: [id], onDelete: Cascade)
  assignments DutyAssignment[]
  swapIOUs    DutySwapIOU[]

  @@index([wgId])
  @@index([wgId, isActive, isPaused])
}

model DutySwapIOU {
  id          String    @id @default(cuid())
  wgId        String
  dutyId      String
  debitorId   String
  creditorId  String
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())

  wg       WGConfig @relation(fields: [wgId], references: [id], onDelete: Cascade)
  duty     Duty     @relation(fields: [dutyId], references: [id], onDelete: Cascade)
  debitor  User     @relation("IouDebitor", fields: [debitorId], references: [id], onDelete: Cascade)
  creditor User     @relation("IouCreditor", fields: [creditorId], references: [id], onDelete: Cascade)

  @@index([wgId])
  @@index([debitorId])
  @@index([creditorId])
}

enum RotationInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  MANUAL
}

model DutyAssignment {
  id                String    @id @default(cuid())
  wgId              String
  dutyId            String
  userId            String
  dueDate           DateTime
  completedAt       DateTime?
  completedBy       String?
  overdueNotifiedAt DateTime?
  createdAt         DateTime  @default(now())

  wg           WGConfig      @relation(fields: [wgId], references: [id], onDelete: Cascade)
  duty         Duty          @relation(fields: [dutyId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  swapRequests SwapRequest[]

  @@index([wgId])
  @@index([wgId, completedAt])
  @@index([wgId, dueDate])
  @@index([userId])
  @@index([dutyId])
}

model SwapRequest {
  id           String     @id @default(cuid())
  wgId         String
  fromUserId   String
  toUserId     String
  assignmentId String
  status       SwapStatus @default(PENDING)
  message      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  wg         WGConfig       @relation(fields: [wgId], references: [id], onDelete: Cascade)
  fromUser   User           @relation("SwapFrom", fields: [fromUserId], references: [id])
  toUser     User           @relation("SwapTo", fields: [toUserId], references: [id])
  assignment DutyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([wgId, status])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([assignmentId])
}

enum SwapStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Announcement {
  id             String    @id @default(cuid())
  wgId           String
  authorId       String
  content        String?
  title          String?
  dueDate        DateTime?
  assignedUserId String?
  createdAt      DateTime  @default(now())

  wg           WGConfig               @relation(fields: [wgId], references: [id], onDelete: Cascade)
  author       User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  assignedUser User?                  @relation("AnnouncementAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  reactions    AnnouncementReaction[]

  @@index([wgId, createdAt])
  @@index([authorId])
}

model AnnouncementReaction {
  id             String @id @default(cuid())
  announcementId String
  userId         String
  emoji          String

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId, emoji])
  @@index([userId])
}

model ShoppingItem {
  id        String    @id @default(cuid())
  wgId      String
  name      String
  category  String    @default("LEBENSMITTEL")
  note      String?
  addedBy   String
  boughtAt  DateTime?
  createdAt DateTime  @default(now())

  wg   WGConfig @relation(fields: [wgId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [addedBy], references: [id])

  @@index([wgId, boughtAt])
  @@index([addedBy])
}

model WGExpenseCategory {
  id        String   @id @default(cuid())
  wgId      String
  name      String
  slug      String
  color     String   @default("#6b7280")
  emoji     String?
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  wg WGConfig @relation(fields: [wgId], references: [id], onDelete: Cascade)

  @@unique([wgId, slug])
}

model Expense {
  id              String    @id @default(cuid())
  wgId            String
  amount          Float
  description     String
  category        String    @default("SONSTIGES")
  paidBy          String
  splitWith       String[]
  splitMode       SplitMode @default(EQUAL)
  splits          Json?
  date            DateTime  @default(now())
  settledAt       DateTime?
  createdAt       DateTime  @default(now())
  gameSessionId   String?
  receiptImageUrl String?

  wg          WGConfig     @relation(fields: [wgId], references: [id], onDelete: Cascade)
  paidByUser  User         @relation(fields: [paidBy], references: [id])
  gameSession GameSession? @relation("GameExpenses", fields: [gameSessionId], references: [id], onDelete: SetNull)

  @@index([wgId, date])
  @@index([wgId, settledAt])
  @@index([paidBy])
}

model Settlement {
  id          String   @id @default(cuid())
  wgId        String
  fromUserId  String
  toUserId    String
  amount      Float
  comment     String?
  createdAt   DateTime @default(now())

  wg       WGConfig @relation(fields: [wgId], references: [id], onDelete: Cascade)
  fromUser User     @relation("SettlementFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User     @relation("SettlementTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([wgId])
  @@index([fromUserId])
  @@index([toUserId])
}

enum SplitMode {
  EQUAL
  INDIVIDUAL
  PERCENTAGE
}

model Notification {
  id        String           @id @default(cuid())
  wgId      String
  userId    String
  type      NotificationType
  message   String
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  wg   WGConfig @relation(fields: [wgId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([wgId, userId])
  @@index([userId, readAt])
}

enum NotificationType {
  ASSIGNMENT
  SWAP_REQUEST
  REMINDER
  ANNOUNCEMENT
  ICAL_REMINDER
  WG_EVENT
  BULLETIN_TASK
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model InviteToken {
  id        String    @id @default(cuid())
  wgId      String
  token     String    @unique @default(cuid())
  createdBy String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  wg WGConfig @relation(fields: [wgId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SpotifyPlaylist {
  id          String   @id @default(cuid())
  userId      String
  wgId        String
  title       String
  description String?
  spotifyUrl  String
  createdAt   DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wg   WGConfig @relation(fields: [wgId], references: [id], onDelete: Cascade)

  @@index([wgId])
  @@index([userId])
}

model ICalCalendar {
  id        String   @id @default(cuid())
  wgId      String
  name      String
  color     String   @default("#6366f1")
  emoji     String   @default("📅")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wg     WGConfig    @relation(fields: [wgId], references: [id], onDelete: Cascade)
  events ICalEvent[]

  @@index([wgId])
}

model ICalEvent {
  id          String    @id @default(cuid())
  calendarId  String
  wgId        String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  uid         String

  calendar ICalCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@unique([calendarId, uid])
  @@index([wgId])
  @@index([calendarId, startDate])
}

model GameSession {
  id         String   @id @default(cuid())
  wgId       String
  gameType   GameType
  multiplier Float    @default(1)
  playedAt   DateTime @default(now())
  createdAt  DateTime @default(now())
  createdBy  String

  wg      WGConfig     @relation(fields: [wgId], references: [id], onDelete: Cascade)
  creator User         @relation("GameCreator", fields: [createdBy], references: [id])
  results GameResult[]
  gameExpenses Expense[] @relation("GameExpenses")

  @@index([wgId, playedAt])
  @@index([createdBy])
}

model GameResult {
  id            String @id @default(cuid())
  gameSessionId String
  userId        String
  points        Int

  session GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@index([gameSessionId])
  @@index([userId])
}

enum GameType {
  SKAT
  DOPPELKOPF
}

model WGEvent {
  id          String    @id @default(cuid())
  wgId        String
  createdBy   String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  notifyWG    Boolean   @default(false)
  color       String    @default("#6366f1")
  emoji       String    @default("📅")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  wg      WGConfig @relation(fields: [wgId], references: [id], onDelete: Cascade)
  creator User     @relation("WGEventCreator", fields: [createdBy], references: [id])

  @@index([wgId, startDate])
  @@index([createdBy])
}
