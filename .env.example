# Datenbank (PostgreSQL via Supabase oder Railway)
DATABASE_URL="postgresql://username:password@host:5432/dbname?sslmode=require"

# NextAuth.js
AUTH_SECRET="your-secret-key-here-min-32-chars-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# E-Mail (Resend oder SendGrid)
EMAIL_FROM="noreply@deine-wg-app.de"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_USER="apikey"
# SMTP_PASS="your-smtp-password"

# App URL (für Einladungslinks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Push Notifications (VAPID Keys)
# Generieren mit: node -e "const wp=require('web-push');console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@deine-wg-app.de"
